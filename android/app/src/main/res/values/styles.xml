<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema base de la aplicación -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#c18c35</item>
        <item name="colorPrimaryDark">#080810</item>
        <item name="colorAccent">#d9a84a</item>
        <item name="android:windowBackground">#080810</item>
        <item name="android:statusBarColor">#080810</item>
        <item name="android:navigationBarColor">#080810</item>
    </style>

    <!-- Tema sin ActionBar para la WebView principal -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">#080810</item>
        <item name="android:navigationBarColor">#080810</item>
    </style>

    <!-- Tema del Splash Screen (aparece mientras carga la app) -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:statusBarColor">#080810</item>
        <item name="android:navigationBarColor">#080810</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
