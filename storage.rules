rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatars de usuario — lectura pública entre usuarios autenticados (imagen de perfil)
    match /avatars/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Logos de empresa (Quotes) — lectura pública entre usuarios autenticados
    match /logos/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Avatar de perfil de feed — lectura pública entre usuarios autenticados
    match /profile/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Feed: archivos multimedia — solo el propietario puede leer/escribir
    match /feed/{uid}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Folders: archivos — solo el propietario puede leer/escribir
    match /folders/{uid}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Denegar todo lo demás por defecto
  }
}
